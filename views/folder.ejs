<div class="p-2 mt-4 p-lg-5 mt-lg-0">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 gap-md-0 mb-5 mb-md-3">
        <h1 class="d-flex align-items-center gap-3">
            <img src="/icons/folder.svg" alt="" class="heading-icon-40">
            <%= title %>
        </h1>
        <a href="/file/upload?folderId=<%= folder.id %> " class="btn btn-primary d-flex align-items-center gap-2">
            <img src="/icons/upload.svg" alt="" class="filter-white btn-icon-24" />
            Upload File
        </a>
    </div>
    
    <% if (locals.folder.files?.length > 0) { %>

        <div class="row mx-0 g-2">
            <% folder.files.forEach(file => { %>
            <div class="card">
                <div class="card-body d-flex justify-content-between align-items-center gap-2">
                    <div class="card-text col col-lg-5"><%= file.name %></div>
                    <div class="card-text col d-none d-md-block"><%= bytes(Number(file.size)) %></div>
                    <div class="card-text col-4 d-none d-md-block"><%= date.format(file.createdAt, 'do MMM yyyy - kk:ss') %></div>
                    <a href="/file/download/<%= file.id %>" class="btn btn-primary btn-sm col-auto">Download</a>
                    <a href="/file/edit/<%= file.id %>" class="btn btn-secondary btn-sm col-auto">Edit</a>
                </div>
            </div>
            <% }) %>
        </div>

    <% } else { %>
        <div class="text-center text-md-start">No files added</div>
    <% } %>
</div>