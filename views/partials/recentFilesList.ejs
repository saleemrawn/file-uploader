<% const recentTenFiles = files.slice(0,10); %> 
<div class="row mx-0 g-2">
    <% recentTenFiles.forEach(file => { %>
    <div class="card">
        <div class="card-body d-flex justify-content-between align-items-center gap-2">
            <div class="card-text col col-lg-5"><%= file.name %></div>
            <div class="card-text col d-none d-lg-block"><%= file.size %></div>
            <div class="card-text col d-none d-lg-flex align-items-center gap-2">
            <%- file.folder ? `<img src="/icons/folder.svg" alt="">${file.folder.name}` : "" %>
            </div>
            <div class="card-text col-4 d-none d-lg-block"><%= file.createdAt %></div>
            <a href="/file/edit/<%= file.id %>" class="btn btn-secondary btn-sm col-auto">Edit</a>
        </div>
    </div>
    <% }) %>
</div>